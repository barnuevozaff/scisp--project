# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Database (MySQL) ────────────────────────────────────
# Local (XAMPP / MySQL Workbench) example:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=scisp_db

# Cloud MySQL example (Railway / PlanetScale / Aiven, etc.)
# DB_HOST=containers-us-west-1.railway.app
# DB_PORT=6543
# DB_USER=root
# DB_PASSWORD=your-cloud-password
# DB_NAME=railway
# DB_SSL=true

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=replace-this-with-a-long-random-string-before-deploying
JWT_EXPIRES_IN=8h

# ── Google OAuth (bonus feature) ────────────────────────────
# Create a free OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# (Application type: Web application). Add your frontend URL under
# "Authorized JavaScript origins". The same Client ID is used on both the
# frontend (to render the Sign in with Google button) and here on the
# backend (to verify the ID token it sends us).
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Email notifications (bonus feature) ─────────────────────
# Free at https://resend.com — sign up, verify your email, and create an
# API key (Dashboard → API Keys). The free tier sends from
# "onboarding@resend.dev" without needing your own domain, which is fine
# for a school project demo.
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=SCISP Events <onboarding@resend.dev>

# ── File uploads ────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5
