# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Database (MySQL) ────────────────────────────────────
# Local (XAMPP / MySQL Workbench) example:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=scisp_db

# Cloud MySQL example (Railway / PlanetScale / Aiven, etc.)
# DB_HOST=containers-us-west-1.railway.app
# DB_PORT=6543
# DB_USER=root
# DB_PASSWORD=your-cloud-password
# DB_NAME=railway
# DB_SSL=true

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=replace-this-with-a-long-random-string-before-deploying
JWT_EXPIRES_IN=8h

# ── File uploads ────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5
